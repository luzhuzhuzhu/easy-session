const PAGE_STYLE = `
  :root {
    --bg1: #061325;
    --bg2: #0b1d38;
    --panel: rgba(13, 23, 42, 0.92);
    --line: #2c456d;
    --text: #e6efff;
    --muted: #98add1;
    --ok: #2dcf73;
    --warn: #d7a042;
    --danger: #ff5f79;
    --btn: #3b8bff;
    --btn-alt: #334b76;
    --touch-target: 44px;
    --mobile-padding: 12px;
  }
  * { box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    margin: 0;
    color: var(--text);
    font-family: "Segoe UI", "SF Pro Display", "PingFang SC", sans-serif;
    background:
      radial-gradient(circle at 12% 10%, rgba(59,139,255,0.32), transparent 38%),
      radial-gradient(circle at 84% 0%, rgba(45,207,115,0.14), transparent 30%),
      linear-gradient(170deg, var(--bg1), var(--bg2));
  }
  .shell {
    width: min(1540px, 97vw);
    margin: 0 auto;
    padding: 14px;
  }
  .card {
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--panel);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.24);
    backdrop-filter: blur(8px);
  }
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
  }
  .title {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
  }
  .muted { color: var(--muted); font-size: 12px; }
  .row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  input, select, button {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: #10203c;
    color: var(--text);
    padding: 9px 10px;
    font-size: 13px;
  }
  button {
    border: none;
    background: var(--btn);
    cursor: pointer;
    transition: transform 0.12s ease, opacity 0.12s ease;
  }
  button:hover { transform: translateY(-1px); opacity: 0.95; }
  button.alt { background: var(--btn-alt); }
  .status-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    display: inline-block;
    background: var(--warn);
  }
  .status-dot.ok { background: var(--ok); }
  .status-dot.err { background: var(--danger); }
  .workspace {
    margin-top: 12px;
    display: grid;
    grid-template-columns: 360px minmax(0, 1fr);
    gap: 12px;
    min-height: calc(100vh - 112px);
  }
  .panel {
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .panel-body {
    padding: 12px;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .session-list {
    flex: 1;
    min-height: 220px;
    overflow: auto;
    display: grid;
    gap: 8px;
  }
  .session-item {
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 9px 10px;
    background: rgba(14, 24, 46, 0.9);
    cursor: pointer;
  }
  .session-item.active {
    border-color: #78afff;
    background: rgba(24, 38, 66, 0.95);
  }
  .session-item-name { font-weight: 700; font-size: 13px; }
  .session-item-meta { color: var(--muted); font-size: 12px; margin-top: 3px; }
  .terminal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .terminal-wrap {
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #040d1f;
    min-height: 0;
    flex: 1;
    padding: 8px;
    overflow: hidden;
  }
  #terminalHost {
    width: 100%;
    height: clamp(320px, calc(100vh - 300px), 72vh);
    min-height: 280px;
    max-height: 72vh;
  }
  .input-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 8px;
  }
  .notice {
    min-height: 18px;
    font-size: 12px;
    color: #d7e5ff;
  }
  .notice.ok { color: #9fe7bb; }
  .notice.error { color: #ff9fb0; }
  /* 移动端抽屉式布局 */
  .drawer-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.5);
    z-index: 999;
  }
  .drawer-overlay.active {
    display: block;
  }
  #drawerBtn {
    display: none;
  }
  .mobile-toolbar {
    display: none;
  }

  /* 移动端（手机竖屏）*/
  @media (max-width: 480px) {
    .shell {
      width: 100%;
      padding: 0;
      margin: 0;
    }
    .card {
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
    .workspace {
      grid-template-columns: 1fr;
      gap: 0;
      min-height: 100vh;
    }
    .panel.sessions-panel {
      position: fixed;
      top: 0;
      left: 0;
      width: 85vw;
      max-width: 320px;
      height: 100vh;
      z-index: 1000;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      box-shadow: 2px 0 8px rgba(0,0,0,0.2);
      border-radius: 0;
    }
    .panel.sessions-panel.open {
      transform: translateX(0);
    }
    #terminalHost {
      height: calc(100vh - 280px);
      min-height: 200px;
    }
    body.keyboard-open #terminalHost {
      height: calc(100vh - 380px);
    }
    .xterm {
      font-size: 14px !important;
    }
    button {
      min-height: var(--touch-target);
      min-width: var(--touch-target);
      padding: 12px 16px;
      font-size: 14px;
    }
    input, select {
      min-height: var(--touch-target);
      padding: 12px 14px;
      font-size: 16px;
    }
    .session-item {
      min-height: var(--touch-target);
      padding: 12px;
      font-size: 14px;
    }
    #drawerBtn {
      display: block;
      position: fixed;
      top: 12px;
      left: 12px;
      z-index: 1001;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 8px 12px;
      font-size: 14px;
      min-width: auto;
    }
    .mobile-toolbar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--panel);
      border-top: 1px solid var(--line);
      padding: 8px;
      gap: 8px;
      z-index: 100;
      box-shadow: 0 -2px 8px rgba(0,0,0,0.1);
    }
    .mobile-toolbar button {
      min-width: var(--touch-target);
      min-height: var(--touch-target);
      padding: 8px;
      font-size: 18px;
      flex-shrink: 0;
    }
    .mobile-toolbar input {
      flex: 1;
      min-height: var(--touch-target);
      padding: 8px 12px;
      font-size: 16px;
    }
  }

  /* 移动端（手机横屏/小平板）*/
  @media (min-width: 481px) and (max-width: 768px) {
    .workspace {
      grid-template-columns: 280px minmax(0, 1fr);
    }
    #terminalHost {
      height: calc(100vh - 320px);
    }
    .xterm {
      font-size: 13px !important;
    }
    button {
      min-height: 40px;
      padding: 10px 14px;
    }
  }

  /* 平板 */
  @media (min-width: 769px) and (max-width: 1080px) {
    .workspace {
      grid-template-columns: 320px minmax(0, 1fr);
      min-height: unset;
    }
    #terminalHost {
      height: clamp(300px, 52vh, 58vh);
      max-height: 58vh;
    }
  }
`;

export function renderLoginPage(defaultBaseUrl: string): string {
  return `<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>EasySession Remote Login</title>
  <style>${PAGE_STYLE}</style>
</head>
<body>
  <div class="shell" style="display:flex; align-items:center; justify-content:center; min-height:100%;">
    <div class="card" style="width:min(720px, 96vw);">
      <div class="header">
        <div>
          <h1 class="title">EasySession Remote</h1>
          <div class="muted">输入远程地址和 Token，保存后进入会话页面。</div>
        </div>
      </div>
      <div class="panel-body">
        <input id="baseUrl" placeholder="Base URL" />
        <input id="token" placeholder="Bearer token" type="password" />
        <div class="row">
          <button id="submitBtn">保存并进入 /sessions</button>
        </div>
        <div id="msg" class="notice"></div>
      </div>
    </div>
  </div>
  <script>
    const keyBase = 'easy_remote_base_url';
    const keyToken = 'easy_remote_token';
    const baseEl = document.getElementById('baseUrl');
    const tokenEl = document.getElementById('token');
    const msgEl = document.getElementById('msg');

    const fallback = '${defaultBaseUrl}';
    const guessed = location.origin && location.origin.startsWith('http') ? location.origin : fallback;
    baseEl.value = (localStorage.getItem(keyBase) || guessed).replace(/\\/$/, '');
    tokenEl.value = localStorage.getItem(keyToken) || '';

    document.getElementById('submitBtn').addEventListener('click', () => {
      const base = (baseEl.value || '').trim().replace(/\\/$/, '');
      const token = (tokenEl.value || '').trim();
      if (!base || !token) {
        msgEl.className = 'notice error';
        msgEl.textContent = '请填写完整的 Base URL 和 token。';
        return;
      }
      localStorage.setItem(keyBase, base);
      localStorage.setItem(keyToken, token);
      location.href = '/sessions';
    });
  </script>
</body>
</html>`;
}

export function renderSessionsPage(defaultBaseUrl: string, passthroughOnly: boolean): string {
  return `<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>EasySession Remote Sessions</title>
  <link rel="stylesheet" href="/remote-assets/xterm.css" />
  <style>${PAGE_STYLE}</style>
</head>
<body>
  <button id="drawerBtn">☰ 会话</button>
  <div class="drawer-overlay"></div>
  <div class="mobile-toolbar">
    <button id="clearBtn" title="清屏">🗑️</button>
    <input id="mobileInput" placeholder="输入命令..." />
    <button id="mobileSendBtn" title="发送">➤</button>
    <button id="pasteBtn" title="粘贴">📋</button>
  </div>
  <div class="shell">
    <div class="card header">
      <div>
        <h1 class="title">EasySession Remote Sessions</h1>
        <div class="muted" id="baseUrlLabel"></div>
      </div>
      <div class="row">
        <span class="status-dot" id="socketDot"></span>
        <span class="muted" id="socketText">Socket: disconnected</span>
        <span class="muted">模式: ${passthroughOnly ? 'Passthrough Only' : 'Full Control'}</span>
        <button class="alt" id="logoutBtn">退出登录</button>
      </div>
    </div>

    <div class="workspace">
      <section class="card panel sessions-panel">
        <div class="panel-body">
          <div style="font-weight:700; font-size:14px;">会话列表</div>
          <div class="row">
            <input id="searchInput" placeholder="搜索会话..." style="flex:1;" />
            <button class="alt" id="refreshBtn">刷新</button>
          </div>
          <div class="muted" id="modeHint"></div>
          <div id="sessionList" class="session-list"></div>
        </div>
      </section>

      <section class="card panel">
        <div class="panel-body" style="height: 100%;">
          <div class="terminal-head">
            <div>
              <div id="activeSessionTitle" style="font-weight:700;">未选择会话</div>
              <div id="activeSessionMeta" class="muted"></div>
            </div>
          </div>

          <div class="terminal-wrap">
            <div id="terminalHost"></div>
          </div>

          <div class="input-row">
            <input id="inputBox" placeholder="输入命令，回车发送（原样透传）" />
            <button id="sendBtn">发送</button>
          </div>
          <div id="notice" class="notice"></div>
        </div>
      </section>
    </div>
  </div>

  <script src="/remote-assets/xterm.js"></script>
  <script src="/remote-assets/xterm-fit.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    const HISTORY_LINES = 200;
    const RESIZE_DEBOUNCE_MS = 140;
    const PASSTHROUGH_ONLY = ${passthroughOnly ? 'true' : 'false'};
    const keyBase = 'easy_remote_base_url';
    const keyToken = 'easy_remote_token';
    const storedBaseUrl = (localStorage.getItem(keyBase) || '').trim().replace(/\\/$/, '');
    const fallbackOrigin = (location.origin || '').trim().replace(/\\/$/, '');
    const defaultBaseUrl = '${defaultBaseUrl}'.replace(/\\/$/, '');
    let currentBaseUrl = storedBaseUrl || fallbackOrigin || defaultBaseUrl;
    const token = localStorage.getItem(keyToken) || '';
    if (!token) location.href = '/login';

    const state = {
      sessions: [],
      activeSessionId: null,
      socket: null,
      connected: false,
      term: null,
      fitAddon: null,
      lastSeqBySession: {},
      resizeTimer: null,
      baseUrl: currentBaseUrl
    };

    const baseUrlLabel = document.getElementById('baseUrlLabel');
    const socketDot = document.getElementById('socketDot');
    const socketText = document.getElementById('socketText');
    const refreshBtn = document.getElementById('refreshBtn');
    const searchInput = document.getElementById('searchInput');
    const sessionListEl = document.getElementById('sessionList');
    const inputBox = document.getElementById('inputBox');
    const sendBtn = document.getElementById('sendBtn');
    const activeSessionTitle = document.getElementById('activeSessionTitle');
    const activeSessionMeta = document.getElementById('activeSessionMeta');
    const logoutBtn = document.getElementById('logoutBtn');
    const noticeEl = document.getElementById('notice');
    const terminalHost = document.getElementById('terminalHost');
    const modeHint = document.getElementById('modeHint');
    const drawerBtn = document.getElementById('drawerBtn');
    const drawerOverlay = document.querySelector('.drawer-overlay');
    const sessionsPanel = document.querySelector('.panel.sessions-panel');
    const clearBtn = document.getElementById('clearBtn');
    const mobileInput = document.getElementById('mobileInput');
    const mobileSendBtn = document.getElementById('mobileSendBtn');
    const pasteBtn = document.getElementById('pasteBtn');

    const isMobile = window.innerWidth <= 480;

    function renderBaseUrlLabel() {
      baseUrlLabel.textContent = 'Base URL: ' + (state.baseUrl || '(unknown)');
    }
    renderBaseUrlLabel();

    // 抽屉控制
    if (drawerBtn && drawerOverlay && sessionsPanel) {
      drawerBtn.addEventListener('click', () => {
        sessionsPanel.classList.add('open');
        drawerOverlay.classList.add('active');
      });
      drawerOverlay.addEventListener('click', () => {
        sessionsPanel.classList.remove('open');
        drawerOverlay.classList.remove('active');
      });
    }

    // 移动端工具栏 - 清屏
    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        if (state.term) {
          state.term.clear();
          setNotice('终端已清屏', 'ok');
        }
      });
    }

    // 移动端工具栏 - 粘贴
    if (pasteBtn) {
      pasteBtn.addEventListener('click', async () => {
        try {
          const text = await navigator.clipboard.readText();
          if (mobileInput) mobileInput.value = text;
          setNotice('已粘贴', 'ok');
        } catch (err) {
          setNotice('粘贴失败', 'error');
        }
      });
    }

    // 移动端工具栏 - 发送
    if (mobileInput && mobileSendBtn) {
      const sendMobileCommand = () => {
        const session = getActiveSession();
        if (!session || !state.socket) return;
        const raw = mobileInput.value;
        if (!raw.trim()) return;
        state.socket.emit('session:input', { sessionId: session.id, input: raw });
        mobileInput.value = '';
      };
      mobileSendBtn.addEventListener('click', sendMobileCommand);
      mobileInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          sendMobileCommand();
        }
      });
    }

    modeHint.textContent = PASSTHROUGH_ONLY
      ? '当前为全透传模式：仅可连接已有会话并透传输入/输出。'
      : '当前为完整控制模式。';

    function setNotice(message, kind = '') {
      noticeEl.className = 'notice' + (kind ? (' ' + kind) : '');
      noticeEl.textContent = message || '';
    }

    function setSocketUi(connected, text) {
      state.connected = connected;
      socketText.textContent = 'Socket: ' + text;
      socketDot.classList.remove('ok', 'err');
      socketDot.classList.add(connected ? 'ok' : 'err');
    }

    function initTerminal() {
      if (!window.Terminal || !window.FitAddon) {
        setNotice('xterm 资源加载失败', 'error');
        return;
      }

      state.term = new window.Terminal({
        cursorBlink: true,
        convertEol: true,
        scrollback: 4000,
        fontSize: 13,
        fontFamily: 'Consolas, "Cascadia Mono", "Courier New", monospace',
        theme: {
          background: '#040d1f',
          foreground: '#d8e4ff',
          cursor: '#8bb6ff',
          selectionBackground: 'rgba(139,182,255,0.25)'
        }
      });
      state.fitAddon = new window.FitAddon.FitAddon();
      state.term.loadAddon(state.fitAddon);
      state.term.open(terminalHost);
      state.fitAddon.fit();
      state.term.writeln('Remote terminal ready.');
    }

    function fitTerminalAndResizeRemote() {
      if (!state.term || !state.fitAddon) return;
      state.fitAddon.fit();
      const active = getActiveSession();
      if (!active || !state.socket || !state.connected) return;
      state.socket.emit('session:resize', {
        sessionId: active.id,
        cols: state.term.cols,
        rows: state.term.rows
      });
    }

    function scheduleTerminalResize() {
      if (state.resizeTimer) clearTimeout(state.resizeTimer);
      state.resizeTimer = setTimeout(fitTerminalAndResizeRemote, RESIZE_DEBOUNCE_MS);
    }

    async function api(path, init) {
      const resp = await fetch(state.baseUrl + path, {
        ...init,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + token,
          ...(init && init.headers ? init.headers : {})
        }
      });
      const body = await resp.json().catch(() => ({}));
      if (!resp.ok) {
        const msg = body && body.message ? body.message : ('Request failed: ' + resp.status);
        throw new Error(msg);
      }
      return body.data;
    }

    async function probeBaseUrl(candidate) {
      const target = (candidate || '').trim().replace(/\\/$/, '');
      if (!target) return { ok: false, baseUrl: target, reason: 'empty base url' };
      try {
        const resp = await fetch(target + '/api/health', {
          headers: { Authorization: 'Bearer ' + token }
        });
        const body = await resp.json().catch(() => ({}));
        if (!resp.ok) {
          return {
            ok: false,
            baseUrl: target,
            reason: body && body.message ? body.message : ('HTTP ' + resp.status)
          };
        }
        return { ok: true, baseUrl: target };
      } catch (err) {
        return {
          ok: false,
          baseUrl: target,
          reason: err && err.message ? err.message : String(err)
        };
      }
    }

    async function resolveWorkingBaseUrl() {
      const candidates = [storedBaseUrl, fallbackOrigin, defaultBaseUrl]
        .map((item) => (item || '').trim().replace(/\\/$/, ''))
        .filter((item, idx, arr) => !!item && arr.indexOf(item) === idx);

      let lastError = 'No candidate baseUrl';
      for (const candidate of candidates) {
        const result = await probeBaseUrl(candidate);
        if (result.ok) {
          state.baseUrl = result.baseUrl;
          localStorage.setItem(keyBase, result.baseUrl);
          renderBaseUrlLabel();
          return;
        }
        lastError = result.baseUrl + ': ' + result.reason;
      }
      throw new Error('无法连接远程服务（请检查地址和 token）：' + lastError);
    }

    function getActiveSession() {
      return state.sessions.find((s) => s.id === state.activeSessionId) || null;
    }

    function updateActiveSessionView() {
      const session = getActiveSession();
      if (!session) {
        activeSessionTitle.textContent = '未选择会话';
        activeSessionMeta.textContent = '';
        return;
      }
      activeSessionTitle.textContent = session.name || session.id;
      activeSessionMeta.textContent = [session.type, session.status, session.projectPath].join(' | ');
    }

    function resetTerminal(sessionId) {
      if (!state.term) return;
      state.lastSeqBySession[sessionId] = 0;
      state.term.clear();
      state.term.write('\x1b[2J\x1b[H');
    }

    function writeOutput(event) {
      if (!state.term || !event || event.sessionId !== state.activeSessionId) return;
      if (typeof event.seq === 'number') {
        const prev = state.lastSeqBySession[event.sessionId] || 0;
        if (event.seq <= prev) return;
        state.lastSeqBySession[event.sessionId] = event.seq;
      }
      const raw = typeof event.data === 'string' ? event.data : String(event.data ?? '');
      if (!raw) return;
      state.term.write(raw);
    }

    function renderSessions() {
      sessionListEl.innerHTML = '';
      const keyword = (searchInput.value || '').trim().toLowerCase();
      const list = state.sessions.filter((s) => {
        if (!keyword) return true;
        return (
          (s.name || '').toLowerCase().includes(keyword) ||
          (s.id || '').toLowerCase().includes(keyword) ||
          (s.type || '').toLowerCase().includes(keyword)
        );
      });

      if (list.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'muted';
        empty.textContent = '暂无匹配会话';
        sessionListEl.appendChild(empty);
      }

      for (const s of list) {
        const el = document.createElement('div');
        el.className = 'session-item' + (s.id === state.activeSessionId ? ' active' : '');
        el.innerHTML =
          '<div class="session-item-name">' + (s.name || s.id) + '</div>' +
          '<div class="session-item-meta">' + [s.type, s.status].join(' | ') + '</div>';
        el.addEventListener('click', () => selectSession(s.id));
        sessionListEl.appendChild(el);
      }
      updateActiveSessionView();
    }

    function selectSession(sessionId) {
      if (state.activeSessionId === sessionId) return;
      if (state.activeSessionId && state.socket) {
        state.socket.emit('session:unsubscribe', { sessionId: state.activeSessionId });
      }

      state.activeSessionId = sessionId;
      resetTerminal(sessionId);
      renderSessions();
      setNotice('');

      // 移动端选择会话后关闭抽屉
      if (isMobile && sessionsPanel && drawerOverlay) {
        sessionsPanel.classList.remove('open');
        drawerOverlay.classList.remove('active');
      }

      if (state.socket) {
        state.socket.emit('session:subscribe', { sessionId, historyLines: HISTORY_LINES }, (ack) => {
          if (ack && ack.ok === false) {
            setNotice('订阅失败: ' + (ack.message || 'unknown'), 'error');
          }
        });
      }
      scheduleTerminalResize();
    }

    async function refreshData() {
      const sessions = await api('/api/sessions');
      let normalized = Array.isArray(sessions) ? sessions.slice() : [];
      if (PASSTHROUGH_ONLY) {
        normalized = normalized.filter((s) => s && s.status === 'running' && !!s.processId);
      }
      normalized.sort((a, b) => (b.lastActiveAt || 0) - (a.lastActiveAt || 0));
      state.sessions = normalized;

      if (state.activeSessionId && !state.sessions.some((s) => s.id === state.activeSessionId)) {
        state.activeSessionId = null;
      }

      renderSessions();
      if (!state.activeSessionId && state.sessions.length > 0) {
        selectSession(state.sessions[0].id);
      }
    }

    function connectSocket() {
      const socket = io(state.baseUrl, {
        transports: ['websocket', 'polling'],
        auth: { token },
        reconnection: true,
        reconnectionDelay: 500,
        reconnectionDelayMax: 6000
      });
      state.socket = socket;

      socket.on('connect', () => {
        setSocketUi(true, 'connected');
        setNotice('实时通道已连接', 'ok');
        const active = getActiveSession();
        if (active) {
          resetTerminal(active.id);
          socket.emit('session:subscribe', { sessionId: active.id, historyLines: HISTORY_LINES });
          scheduleTerminalResize();
        }
      });

      socket.on('disconnect', () => {
        setSocketUi(false, 'disconnected');
        setNotice('实时通道已断开，正在重连...', 'error');
      });

      socket.on('connect_error', (err) => {
        const message = err && err.message ? err.message : 'unknown';
        setSocketUi(false, 'error: ' + message);
        setNotice('连接失败: ' + message, 'error');
      });

      socket.on('session:output', writeOutput);

      socket.on('session:status', (event) => {
        const target = state.sessions.find((s) => s.id === event.sessionId);
        if (target) target.status = event.status;
        renderSessions();
      });
    }

    async function safeAction(label, fn) {
      try {
        await fn();
      } catch (err) {
        setNotice(label + '失败: ' + (err && err.message ? err.message : String(err)), 'error');
      }
    }

    refreshBtn.addEventListener('click', () => safeAction('刷新', async () => {
      await refreshData();
      setNotice('已刷新', 'ok');
    }));

    searchInput.addEventListener('input', renderSessions);

    function sendCurrentInput() {
      const session = getActiveSession();
      if (!session || !state.socket) return;
      const raw = inputBox.value;
      state.socket.emit('session:input', { sessionId: session.id, input: raw }, (ack) => {
        if (ack && ack.ok === false) {
          setNotice('发送失败: ' + (ack.message || 'unknown'), 'error');
          return;
        }
        setNotice('');
      });
      inputBox.value = '';
    }

    sendBtn.addEventListener('click', sendCurrentInput);
    inputBox.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        sendCurrentInput();
      }
    });

    logoutBtn.addEventListener('click', () => {
      localStorage.removeItem(keyToken);
      location.href = '/login';
    });

    // 虚拟键盘适配
    if (inputBox) {
      inputBox.addEventListener('focus', () => {
        document.body.classList.add('keyboard-open');
        setTimeout(scheduleTerminalResize, 300);
      });
      inputBox.addEventListener('blur', () => {
        document.body.classList.remove('keyboard-open');
        setTimeout(scheduleTerminalResize, 300);
      });
    }

    // visualViewport API 精确检测
    if (window.visualViewport) {
      window.visualViewport.addEventListener('resize', () => {
        const viewportHeight = window.visualViewport.height;
        const windowHeight = window.innerHeight;
        if (viewportHeight < windowHeight * 0.75) {
          document.body.classList.add('keyboard-open');
        } else {
          document.body.classList.remove('keyboard-open');
        }
        scheduleTerminalResize();
      });
    }

    // 触摸手势支持
    if (terminalHost) {
      let longPressTimer = null;
      let lastTap = 0;
      let touchStartX = 0;
      let touchStartY = 0;

      terminalHost.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        longPressTimer = setTimeout(() => {
          if (state.term) {
            const selection = state.term.getSelection();
            if (selection) {
              navigator.clipboard.writeText(selection).then(() => {
                setNotice('已复制到剪贴板', 'ok');
              }).catch(() => {
                setNotice('复制失败', 'error');
              });
            }
          }
        }, 600);
      });

      terminalHost.addEventListener('touchmove', (e) => {
        const moveX = Math.abs(e.touches[0].clientX - touchStartX);
        const moveY = Math.abs(e.touches[0].clientY - touchStartY);
        if (moveX > 10 || moveY > 10) {
          clearTimeout(longPressTimer);
        }
      });

      terminalHost.addEventListener('touchend', (e) => {
        clearTimeout(longPressTimer);
        const now = Date.now();
        if (now - lastTap < 300) {
          if (state.term) {
            state.term.clear();
            setNotice('终端已清屏', 'ok');
          }
        }
        lastTap = now;
      });
    }

    // 左滑打开会话列表
    if (isMobile && sessionsPanel && drawerOverlay) {
      let swipeStartX = 0;
      document.body.addEventListener('touchstart', (e) => {
        swipeStartX = e.touches[0].clientX;
      });
      document.body.addEventListener('touchend', (e) => {
        const swipeEndX = e.changedTouches[0].clientX;
        const swipeDistance = swipeEndX - swipeStartX;
        if (swipeStartX < 30 && swipeDistance > 80) {
          sessionsPanel.classList.add('open');
          drawerOverlay.classList.add('active');
        }
      });
    }

    window.addEventListener('resize', scheduleTerminalResize);

    (async () => {
      initTerminal();
      try {
        await resolveWorkingBaseUrl();
        await refreshData();
        connectSocket();
        scheduleTerminalResize();
      } catch (err) {
        setNotice('初始化失败: ' + (err && err.message ? err.message : String(err)), 'error');
      }
    })();
  </script>
</body>
</html>`;
}
