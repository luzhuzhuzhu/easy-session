const PAGE_STYLE = `
  :root {
    --bg1: #061325;
    --bg2: #0b1d38;
    --panel: rgba(13, 23, 42, 0.92);
    --line: #2c456d;
    --text: #e6efff;
    --muted: #98add1;
    --ok: #2dcf73;
    --warn: #d7a042;
    --danger: #ff5f79;
    --btn: #3b8bff;
    --btn-alt: #334b76;
    --touch-target: 44px;
    --mobile-padding: 12px;
  }
  * { box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    margin: 0;
    color: var(--text);
    font-family: "Segoe UI", "SF Pro Display", "PingFang SC", sans-serif;
    background:
      radial-gradient(circle at 12% 10%, rgba(59,139,255,0.32), transparent 38%),
      radial-gradient(circle at 84% 0%, rgba(45,207,115,0.14), transparent 30%),
      linear-gradient(170deg, var(--bg1), var(--bg2));
  }
  .shell {
    width: min(1540px, 97vw);
    margin: 0 auto;
    padding: 14px;
  }
  .card {
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--panel);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.24);
    backdrop-filter: blur(8px);
  }
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
  }
  .header-copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .status-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 30px;
    padding: 0 10px;
    border: 1px solid rgba(120, 175, 255, 0.14);
    border-radius: 999px;
    background: rgba(9, 18, 33, 0.6);
    color: var(--muted);
    font-size: 12px;
    white-space: nowrap;
  }
  .title {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
  }
  .muted { color: var(--muted); font-size: 12px; }
  .row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .remember-row {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--muted);
    font-size: 13px;
  }
  .remember-row input[type="checkbox"] {
    width: 16px;
    height: 16px;
    padding: 0;
    accent-color: var(--btn);
  }
  .remember-note {
    color: var(--muted);
    font-size: 12px;
    line-height: 1.5;
  }
  input, select, button {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: #10203c;
    color: var(--text);
    padding: 9px 10px;
    font-size: 13px;
  }
  button {
    border: none;
    background: var(--btn);
    cursor: pointer;
    transition: transform 0.12s ease, opacity 0.12s ease;
  }
  button:hover { transform: translateY(-1px); opacity: 0.95; }
  button:disabled {
    cursor: not-allowed;
    opacity: 0.45;
    transform: none;
  }
  button.alt { background: var(--btn-alt); }
  .status-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    display: inline-block;
    background: var(--warn);
  }
  .status-dot.ok { background: var(--ok); }
  .status-dot.err { background: var(--danger); }
  .workspace {
    margin-top: 12px;
    display: grid;
    grid-template-columns: 360px minmax(0, 1fr);
    gap: 12px;
    min-height: calc(100vh - 112px);
  }
  .panel {
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .panel-body {
    padding: 12px;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .session-list {
    flex: 1;
    min-height: 220px;
    overflow: auto;
    display: grid;
    gap: 8px;
  }
  .session-item {
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 9px 10px;
    background: rgba(14, 24, 46, 0.9);
    cursor: pointer;
  }
  .session-item.active {
    border-color: #78afff;
    background: rgba(24, 38, 66, 0.95);
  }
  .session-item-name { font-weight: 700; font-size: 13px; }
  .session-item-meta { color: var(--muted); font-size: 12px; margin-top: 3px; }
  .terminal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .session-action-group {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .session-action-group:empty {
    display: none;
  }
  .session-action-btn {
    min-height: 34px;
    padding: 7px 12px;
    border-radius: 10px;
    border: 1px solid rgba(120, 175, 255, 0.18);
    background: rgba(16, 32, 60, 0.96);
    color: var(--text);
    font-size: 12px;
  }
  .session-action-btn.warn {
    background: rgba(215, 160, 66, 0.14);
    color: #ffd48a;
  }
  .session-action-btn.danger {
    background: rgba(255, 95, 121, 0.14);
    color: #ffc0cb;
  }
  .terminal-wrap {
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #040d1f;
    min-height: 0;
    flex: 1;
    padding: 8px;
    overflow: hidden;
    overscroll-behavior: contain;
  }
  .plain-terminal {
    width: 100%;
    height: 100%;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 10px;
    color: #d8e4ff;
  }
  .plain-terminal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .plain-terminal-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 8px;
    border-radius: 999px;
    background: rgba(215, 160, 66, 0.16);
    color: #ffd48a;
    font-size: 12px;
  }
  .plain-terminal-output {
    margin: 0;
    flex: 1;
    min-height: 0;
    overflow: auto;
    padding: 10px;
    border-radius: 10px;
    border: 1px solid rgba(120, 175, 255, 0.16);
    background: rgba(4, 13, 31, 0.96);
    white-space: pre-wrap;
    word-break: break-word;
    font: 13px/1.55 Consolas, "Cascadia Mono", "Courier New", monospace;
  }
  .plain-terminal-empty {
    color: var(--muted);
  }
  #terminalHost {
    width: 100%;
    height: clamp(320px, calc(100vh - 300px), 72vh);
    min-height: 280px;
    max-height: 72vh;
  }
  .input-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 8px;
  }
  .notice {
    min-height: 18px;
    font-size: 12px;
    color: #d7e5ff;
  }
  .notice.ok { color: #9fe7bb; }
  .notice.error { color: #ff9fb0; }
  .global-notice {
    margin-top: 10px;
    padding: 10px 12px;
    border: 1px solid rgba(120, 175, 255, 0.16);
    border-radius: 12px;
    background: rgba(7, 17, 33, 0.72);
    min-height: 0;
  }
  .global-notice:empty {
    display: none;
  }
  /* 移动端视图 */
  .mobile-view {
    display: none;
  }
  .xterm-viewport {
    overflow-y: auto !important;
    -webkit-overflow-scrolling: touch;
  }
  #terminalHost, #mobileTerminalHost {
    overscroll-behavior: contain;
  }
  #backBtn {
    display: none;
  }

  /* 移动端（手机竖屏）*/
  @media (max-width: 480px) {
    body {
      overflow: hidden;
    }
    .shell {
      width: 100%;
      height: 100vh;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
    }
    .card.header {
      border-radius: 0;
      border-left: none;
      border-right: none;
      border-top: none;
      flex-shrink: 0;
      padding: 12px 14px;
      align-items: flex-start;
    }
    .title {
      font-size: 18px;
    }
    .header-copy {
      gap: 2px;
    }
    #baseUrlLabel,
    #modeLabel {
      display: none;
    }
    .status-row {
      width: 100%;
      justify-content: space-between;
      gap: 6px;
    }
    .status-pill {
      min-height: 28px;
      padding: 0 8px;
      font-size: 11px;
    }
    .global-notice {
      margin: 0;
      border-left: none;
      border-right: none;
      border-top: none;
      border-radius: 0;
      padding: 8px 14px;
    }
    .workspace {
      display: none;
    }

    .mobile-view {
      display: none;
      flex: 1;
      overflow: hidden;
      flex-direction: column;
    }
    body.view-sessions .mobile-view.sessions-view {
      display: flex;
    }
    body.view-terminal .mobile-view.terminal-view {
      display: flex;
    }

    .sessions-view {
      padding: 16px;
      overflow-y: auto;
    }
    .sessions-view input {
      width: 100%;
      margin-bottom: 16px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--panel);
      color: var(--text);
      min-height: var(--touch-target);
      padding: 12px 16px;
      font-size: 16px;
    }
    .session-card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 20px;
      margin-bottom: 16px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .session-card:active {
      transform: scale(0.98);
      opacity: 0.9;
    }
    .session-card-name {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .session-card-meta {
      font-size: 14px;
      color: var(--muted);
    }

    .terminal-view {
      background: #040d1f;
    }
    .terminal-view-header {
      padding: 16px;
      background: var(--panel);
      border-bottom: 1px solid var(--line);
      display: flex;
      align-items: center;
      gap: 12px;
    }
    #backBtn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: var(--touch-target);
      min-height: var(--touch-target);
      padding: 0;
      font-size: 24px;
      border-radius: 12px;
    }
    .terminal-view-title {
      flex: 1;
      font-size: 16px;
      font-weight: 700;
    }
    .mobile-session-actions {
      padding: 0 16px 12px;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      background: var(--panel);
      border-bottom: 1px solid var(--line);
    }
    .mobile-session-actions:empty {
      display: none;
    }
    .terminal-view-body {
      flex: 1;
      overflow: auto;
      padding: 8px;
      -webkit-overflow-scrolling: touch;
    }
    #terminalHost, #mobileTerminalHost {
      height: 100%;
      max-height: none;
      overflow: auto;
      touch-action: pan-y;
    }
    .terminal-view-input {
      flex-shrink: 0;
      background: var(--panel);
      border-top: 1px solid var(--line);
      padding: 12px;
      display: flex;
      gap: 8px;
    }
    .terminal-view-input input {
      flex: 1;
      min-height: var(--touch-target);
      font-size: 16px;
      padding: 12px 16px;
      border-radius: 12px;
    }
    .terminal-view-input button {
      min-width: var(--touch-target);
      min-height: var(--touch-target);
      padding: 12px 20px;
      font-size: 16px;
      border-radius: 12px;
    }
  }

  /* 移动端（手机横屏/小平板）*/
  @media (min-width: 481px) and (max-width: 768px) {
    .workspace {
      grid-template-columns: 280px minmax(0, 1fr);
    }
    #terminalHost {
      height: calc(100vh - 320px);
    }
    .xterm {
      font-size: 13px !important;
    }
    button {
      min-height: 40px;
      padding: 10px 14px;
    }
  }

  /* 平板 */
  @media (min-width: 769px) and (max-width: 1080px) {
    .workspace {
      grid-template-columns: 320px minmax(0, 1fr);
      min-height: unset;
    }
    #terminalHost {
      height: clamp(300px, 52vh, 58vh);
      max-height: 58vh;
    }
  }
`;

export function renderLoginPage(defaultBaseUrl: string): string {
  return `<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>EasySession Remote Mobile Login</title>
  <style>${PAGE_STYLE}</style>
</head>
<body>
  <div class="shell" style="display:flex; align-items:center; justify-content:center; min-height:100%;">
    <div class="card" style="width:min(720px, 96vw);">
      <div class="header">
        <div>
          <h1 class="title">EasySession Remote</h1>
          <div class="muted">面向移动端与浏览器应急入口。电脑端长期使用建议直接打开 EasySession 桌面客户端。</div>
        </div>
      </div>
      <div class="panel-body">
        <input id="baseUrl" placeholder="Base URL" />
        <input id="token" placeholder="Bearer token" type="password" />
        <label class="remember-row" for="rememberDevice">
          <input id="rememberDevice" type="checkbox" />
          <span>记住此设备上的远程登录信息</span>
        </label>
        <div class="remember-note">默认仅保存在当前标签页，关闭标签页后需要重新登录，更适合共享浏览器或临时设备。</div>
        <div class="row">
          <button id="submitBtn">保存并进入会话页</button>
        </div>
        <div id="msg" class="notice"></div>
      </div>
    </div>
  </div>
  <script>
    const keyBase = 'easy_remote_base_url';
    const keyToken = 'easy_remote_token';
    const keyRemember = 'easy_remote_remember';
    const baseEl = document.getElementById('baseUrl');
    const tokenEl = document.getElementById('token');
    const msgEl = document.getElementById('msg');
    const rememberEl = document.getElementById('rememberDevice');

    const fallback = '${defaultBaseUrl}';
    const guessed = location.origin && location.origin.startsWith('http') ? location.origin : fallback;
    const hasPersistedAuth = localStorage.getItem(keyRemember) === '1' || !!localStorage.getItem(keyToken);
    const storedBase = sessionStorage.getItem(keyBase) || localStorage.getItem(keyBase) || guessed;
    const storedToken = sessionStorage.getItem(keyToken) || localStorage.getItem(keyToken) || '';
    baseEl.value = (guessed || storedBase).replace(/\\/$/, '');
    tokenEl.value = storedToken;
    rememberEl.checked = hasPersistedAuth;

    function persistAuth(base, token, remember) {
      if (remember) {
        localStorage.setItem(keyRemember, '1');
        localStorage.setItem(keyBase, base);
        localStorage.setItem(keyToken, token);
        sessionStorage.removeItem(keyBase);
        sessionStorage.removeItem(keyToken);
        return;
      }
      sessionStorage.setItem(keyBase, base);
      sessionStorage.setItem(keyToken, token);
      localStorage.removeItem(keyRemember);
      localStorage.removeItem(keyBase);
      localStorage.removeItem(keyToken);
    }

    document.getElementById('submitBtn').addEventListener('click', () => {
      const base = (baseEl.value || '').trim().replace(/\\/$/, '');
      const token = (tokenEl.value || '').trim();
      const remember = !!rememberEl.checked;
      if (!base || !token) {
        msgEl.className = 'notice error';
        msgEl.textContent = '请填写完整的 Base URL 和 token。';
        return;
      }
      persistAuth(base, token, remember);
      location.href = '/sessions';
    });
  </script>
</body>
</html>`;
}

export function renderSessionsPage(defaultBaseUrl: string, passthroughOnly: boolean): string {
  return `<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>EasySession Remote Mobile Sessions</title>
  <link rel="stylesheet" href="/remote-assets/xterm.css" />
  <style>${PAGE_STYLE}</style>
</head>
<body class="view-sessions">
  <div class="shell">
    <div class="card header">
      <div class="header-copy">
        <h1 class="title">EasySession Remote Sessions</h1>
        <div class="muted" id="baseUrlLabel"></div>
        <div class="muted">移动端正式入口 / 浏览器应急入口。电脑端建议使用桌面客户端挂载远程实例。</div>
      </div>
      <div class="status-row">
        <span class="status-pill">
          <span class="status-dot" id="socketDot"></span>
          <span id="socketText">Socket: disconnected</span>
        </span>
        <span class="status-pill" id="modeLabel">模式: ${passthroughOnly ? '仅透传' : '允许远程控制'}</span>
        <button class="alt" id="logoutBtn">退出登录</button>
      </div>
    </div>
    <div id="globalNotice" class="notice global-notice"></div>

    <div class="workspace">
      <section class="card panel sessions-panel">
        <div class="panel-body">
          <div style="font-weight:700; font-size:14px;">可连接会话</div>
          <div class="row">
            <input id="searchInput" placeholder="搜索会话..." style="flex:1;" />
            <button class="alt" id="refreshBtn">刷新</button>
          </div>
          <div class="muted" id="modeHint"></div>
          <div id="sessionList" class="session-list"></div>
        </div>
      </section>

      <section class="card panel">
        <div class="panel-body" style="height: 100%;">
        <div class="terminal-head">
          <div>
            <div id="activeSessionTitle" style="font-weight:700;">未选择会话</div>
            <div id="activeSessionMeta" class="muted"></div>
          </div>
          <div id="terminalActions" class="session-action-group"></div>
        </div>

          <div class="terminal-wrap">
            <div id="terminalHost"></div>
          </div>

          <div class="input-row">
            <input id="inputBox" placeholder="输入命令，回车发送（原样透传）" />
            <button id="sendBtn">发送</button>
          </div>
          <div id="notice" class="notice"></div>
        </div>
      </section>
    </div>

    <div class="mobile-view sessions-view">
      <input id="mobileSearchInput" placeholder="搜索会话..." style="margin-bottom:16px;" />
      <div id="mobileSessionList"></div>
    </div>

    <div class="mobile-view terminal-view">
      <div class="terminal-view-header">
        <button id="backBtn">←</button>
        <div class="terminal-view-title" id="mobileSessionTitle">未选择会话</div>
      </div>
      <div id="mobileSessionActions" class="mobile-session-actions"></div>
      <div class="terminal-view-body">
        <div id="mobileTerminalHost"></div>
      </div>
      <div class="terminal-view-input">
        <input id="mobileInputBox" placeholder="输入命令..." />
        <button id="mobileSendBtn">发送</button>
      </div>
    </div>
  </div>

  <script src="/remote-assets/xterm.js"></script>
  <script src="/remote-assets/xterm-fit.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script>
    const HISTORY_LINES = 200;
    const RESIZE_DEBOUNCE_MS = 140;
    const LIST_AUTO_REFRESH_INTERVAL_MS = 15000;
    const MOBILE_BREAKPOINT_QUERY = '(max-width: 480px)';
    const PASSTHROUGH_ONLY = ${passthroughOnly ? 'true' : 'false'};
    const keyBase = 'easy_remote_base_url';
    const keyToken = 'easy_remote_token';
    const keyRemember = 'easy_remote_remember';
    const storageRemembered = localStorage.getItem(keyRemember) === '1'
      || (!!localStorage.getItem(keyToken) && !sessionStorage.getItem(keyToken));
    const authStorage = storageRemembered ? localStorage : sessionStorage;
    function normalizeBaseUrl(value) {
      return (value || '').trim().replace(/\\/$/, '');
    }
    const storedBaseUrl = normalizeBaseUrl(sessionStorage.getItem(keyBase) || localStorage.getItem(keyBase) || '');
    const fallbackOrigin = normalizeBaseUrl(location.origin || '');
    const defaultBaseUrl = normalizeBaseUrl('${defaultBaseUrl}');
    let currentBaseUrl = storedBaseUrl || fallbackOrigin || defaultBaseUrl;
    const token = sessionStorage.getItem(keyToken) || localStorage.getItem(keyToken) || '';
    if (!token) location.href = '/login';

    const state = {
      sessions: [],
      activeSessionId: null,
      capabilities: {
        sessionStart: !PASSTHROUGH_ONLY,
        sessionPause: !PASSTHROUGH_ONLY,
        sessionRestart: !PASSTHROUGH_ONLY,
        sessionDestroy: !PASSTHROUGH_ONLY
      },
      socket: null,
      connected: false,
      term: null,
      fitAddon: null,
      plainTerminalEl: null,
      terminalMode: 'uninitialized',
      termLayoutMode: null,
      currentView: 'sessions',
      lastSeqBySession: {},
      plainBufferBySession: {},
      resizeTimer: null,
      idleTimeoutPending: false,
      lastSocketError: '',
      socketReconnectInFlight: false,
      controlBusyAction: '',
      baseUrl: currentBaseUrl
    };
    const mobileMedia = window.matchMedia ? window.matchMedia(MOBILE_BREAKPOINT_QUERY) : null;
    const baseUrlLabel = document.getElementById('baseUrlLabel');
    const socketDot = document.getElementById('socketDot');
    const socketText = document.getElementById('socketText');
    const refreshBtn = document.getElementById('refreshBtn');
    const desktopSearchInput = document.getElementById('searchInput');
    const mobileSearchInput = document.getElementById('mobileSearchInput');
    const desktopSessionListEl = document.getElementById('sessionList');
    const mobileSessionListEl = document.getElementById('mobileSessionList');
    const desktopInputBox = document.getElementById('inputBox');
    const mobileInputBox = document.getElementById('mobileInputBox');
    const desktopSendBtn = document.getElementById('sendBtn');
    const mobileSendBtn = document.getElementById('mobileSendBtn');
    const desktopSessionActionsEl = document.getElementById('terminalActions');
    const mobileSessionActionsEl = document.getElementById('mobileSessionActions');
    const desktopActiveSessionTitle = document.getElementById('activeSessionTitle');
    const mobileActiveSessionTitle = document.getElementById('mobileSessionTitle');
    const activeSessionMeta = document.getElementById('activeSessionMeta');
    const logoutBtn = document.getElementById('logoutBtn');
    const noticeEl = document.getElementById('notice');
    const globalNoticeEl = document.getElementById('globalNotice');
    const desktopTerminalHost = document.getElementById('terminalHost');
    const mobileTerminalHost = document.getElementById('mobileTerminalHost');
    const modeHint = document.getElementById('modeHint');
    const backBtn = document.getElementById('backBtn');

    function persistBaseUrl(baseUrl) {
      if (!baseUrl) return;
      authStorage.setItem(keyBase, baseUrl);
      if (authStorage !== localStorage) {
        localStorage.removeItem(keyBase);
      }
    }

    function isMobileLayout() {
      return mobileMedia ? mobileMedia.matches : window.innerWidth <= 480;
    }

    function getTerminalHost() {
      return isMobileLayout() ? mobileTerminalHost : desktopTerminalHost;
    }

    function getSearchKeyword() {
      const desktopValue = desktopSearchInput ? desktopSearchInput.value : '';
      const mobileValue = mobileSearchInput ? mobileSearchInput.value : '';
      return (isMobileLayout() ? mobileValue : desktopValue || mobileValue).trim().toLowerCase();
    }

    function syncSearchInputs(value) {
      if (desktopSearchInput && desktopSearchInput.value !== value) desktopSearchInput.value = value;
      if (mobileSearchInput && mobileSearchInput.value !== value) mobileSearchInput.value = value;
    }

    function clearInputBoxes() {
      if (desktopInputBox) desktopInputBox.value = '';
      if (mobileInputBox) mobileInputBox.value = '';
    }

    function renderBaseUrlLabel() {
      baseUrlLabel.textContent = 'Base URL: ' + (state.baseUrl || '(unknown)');
    }
    renderBaseUrlLabel();

    function applyBaseUrl(baseUrl, persist = true) {
      const normalized = normalizeBaseUrl(baseUrl);
      if (!normalized) return;
      state.baseUrl = normalized;
      currentBaseUrl = normalized;
      if (persist) {
        persistBaseUrl(normalized);
      }
      renderBaseUrlLabel();
    }

    function buildBaseUrlCandidates(preferredBaseUrl) {
      const ordered = [
        normalizeBaseUrl(preferredBaseUrl || ''),
        fallbackOrigin,
        storedBaseUrl,
        defaultBaseUrl,
        normalizeBaseUrl(currentBaseUrl)
      ];
      const next = [];
      for (const candidate of ordered) {
        if (!candidate || next.includes(candidate)) continue;
        next.push(candidate);
      }
      return next;
    }

    // 视图切换
    function switchToView(viewName) {
      state.currentView = viewName;
      document.body.className = 'view-' + viewName;
      if (viewName === 'terminal') {
        ensureTerminal(true);
        setTimeout(() => {
          if (!state.term || !state.fitAddon) return;
          state.fitAddon.fit();
          fitTerminalAndResizeRemote();
        }, 100);
      }
    }

    if (backBtn) {
      backBtn.addEventListener('click', () => switchToView('sessions'));
    }

    modeHint.textContent = PASSTHROUGH_ONLY
      ? '当前为仅透传模式：仅可连接已有会话并透传输入/输出，适合手机和浏览器应急使用。'
      : '当前已开启远程控制模式。电脑端仍建议优先使用桌面客户端。';

    function applyNotice(target, message, kind) {
      if (!target) return;
      target.className = 'notice' + (target === globalNoticeEl ? ' global-notice' : '') + (kind ? (' ' + kind) : '');
      target.textContent = message || '';
    }

    function setInlineNotice(message, kind = '') {
      applyNotice(noticeEl, message, kind);
    }

    function setGlobalNotice(message, kind = '') {
      applyNotice(globalNoticeEl, message, kind);
    }

    function clearGlobalNotice() {
      applyNotice(globalNoticeEl, '', '');
    }

    function setNotice(message, kind = '') {
      setInlineNotice(message, kind);
    }

    function getDefaultInputPlaceholder() {
      return isMobileLayout() ? '输入命令后点击发送' : '输入命令，回车发送（原样透传）';
    }

    function updateInputAvailability() {
      const activeSession = getActiveSession();
      const connected = !!(state.socket && state.connected);
      const disabled = !activeSession || !connected;
      const placeholder = !activeSession
        ? '请先选择会话'
        : !connected
          ? '实时通道未连接，暂时无法发送'
          : getDefaultInputPlaceholder();

      for (const inputEl of [desktopInputBox, mobileInputBox]) {
        if (!inputEl) continue;
        inputEl.disabled = disabled;
        inputEl.placeholder = placeholder;
      }

      for (const buttonEl of [desktopSendBtn, mobileSendBtn]) {
        if (!buttonEl) continue;
        buttonEl.disabled = disabled;
      }
    }

    function canManageSessions() {
      return !PASSTHROUGH_ONLY && (
        state.capabilities.sessionStart ||
        state.capabilities.sessionPause ||
        state.capabilities.sessionRestart ||
        state.capabilities.sessionDestroy
      );
    }

    function clearSessionActionButtons() {
      for (const target of [desktopSessionActionsEl, mobileSessionActionsEl]) {
        if (target) target.textContent = '';
      }
    }

    function getSessionActionDescriptors(session) {
      if (!session || !canManageSessions()) return [];
      const actions = [];
      if (state.capabilities.sessionStart && session.status !== 'running') {
        actions.push({ action: 'start', label: '启动', className: '' });
      }
      if (state.capabilities.sessionPause && session.status === 'running') {
        actions.push({ action: 'pause', label: '暂停', className: 'warn' });
      }
      if (state.capabilities.sessionRestart) {
        actions.push({ action: 'restart', label: '重启', className: '' });
      }
      if (state.capabilities.sessionDestroy) {
        actions.push({ action: 'destroy', label: '删除', className: 'danger' });
      }
      return actions;
    }

    function renderSessionActionButtons() {
      const session = getActiveSession();
      const descriptors = getSessionActionDescriptors(session);
      for (const target of [desktopSessionActionsEl, mobileSessionActionsEl]) {
        if (!target) continue;
        target.textContent = '';
        for (const descriptor of descriptors) {
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'session-action-btn' + (descriptor.className ? (' ' + descriptor.className) : '');
          button.textContent = state.controlBusyAction === descriptor.action ? (descriptor.label + '中...') : descriptor.label;
          button.disabled = !!state.controlBusyAction;
          button.addEventListener('click', () => {
            void handleSessionControl(descriptor.action);
          });
          target.appendChild(button);
        }
      }
    }

    async function loadRemoteCapabilities() {
      try {
        const response = await api('/api/capabilities');
        const capabilities = response && response.capabilities ? response.capabilities : {};
        state.capabilities = {
          ...state.capabilities,
          sessionStart: !!capabilities.sessionStart,
          sessionPause: !!capabilities.sessionPause,
          sessionRestart: !!capabilities.sessionRestart,
          sessionDestroy: !!capabilities.sessionDestroy
        };
      } catch (error) {
        state.capabilities = {
          ...state.capabilities,
          sessionStart: !PASSTHROUGH_ONLY,
          sessionPause: !PASSTHROUGH_ONLY,
          sessionRestart: !PASSTHROUGH_ONLY,
          sessionDestroy: !PASSTHROUGH_ONLY
        };
      }
    }

    function setSocketUi(connected, text) {
      state.connected = connected;
      socketText.textContent = 'Socket: ' + text;
      socketDot.classList.remove('ok', 'err');
      socketDot.classList.add(connected ? 'ok' : 'err');
      updateInputAvailability();
    }

    function clearTerminalHosts() {
      if (desktopTerminalHost) desktopTerminalHost.textContent = '';
      if (mobileTerminalHost) mobileTerminalHost.textContent = '';
    }

    function destroyTerminal() {
      if (state.term) {
        state.term.dispose();
      }
      state.term = null;
      state.fitAddon = null;
      state.plainTerminalEl = null;
      state.terminalMode = 'uninitialized';
      state.termLayoutMode = null;
      clearTerminalHosts();
    }

    function stripAnsi(value) {
      return String(value ?? '')
        .replace(/\\u001b\\][^\\u0007]*(?:\\u0007|\\u001b\\\\)/g, '')
        .replace(/\\u001b\\[[0-9;?]*[ -/]*[@-~]/g, '')
        .replace(/\\u001b[@-_]/g, '');
    }

    function createPlainTerminal(host, reason) {
      clearTerminalHosts();
      if (!host) {
        setNotice('终端容器不可用', 'error');
        return;
      }

      const wrapper = document.createElement('div');
      wrapper.className = 'plain-terminal';

      const head = document.createElement('div');
      head.className = 'plain-terminal-head';

      const title = document.createElement('div');
      title.className = 'muted';
      title.textContent = '当前处于兼容降级模式，仍可查看输出与透传输入。';

      const badge = document.createElement('span');
      badge.className = 'plain-terminal-badge';
      badge.textContent = '纯文本兼容模式';

      head.appendChild(title);
      head.appendChild(badge);

      const output = document.createElement('pre');
      output.className = 'plain-terminal-output plain-terminal-empty';
      output.textContent = '终端资源不可用时，将在这里以纯文本形式显示输出。';

      wrapper.appendChild(head);
      wrapper.appendChild(output);
      host.appendChild(wrapper);

      state.plainTerminalEl = output;
      state.terminalMode = 'plain';
      state.termLayoutMode = isMobileLayout() ? 'mobile' : 'desktop';
      setNotice(reason || 'xterm 资源加载失败，已切换到纯文本兼容模式。', 'error');
    }

    function setPlainTerminalContent(value) {
      if (!state.plainTerminalEl) return;
      const nextValue = value || '';
      state.plainTerminalEl.textContent = nextValue || '终端资源不可用时，将在这里以纯文本形式显示输出。';
      state.plainTerminalEl.classList.toggle('plain-terminal-empty', !nextValue);
      state.plainTerminalEl.scrollTop = state.plainTerminalEl.scrollHeight;
    }

    function appendPlainOutput(raw) {
      const session = getActiveSession();
      if (!session) return;
      const cleanText = stripAnsi(raw);
      const previous = state.plainBufferBySession[session.id] || '';
      const nextValue = previous + cleanText;
      state.plainBufferBySession[session.id] = nextValue;
      setPlainTerminalContent(nextValue);
    }

    function initTerminal(forceRecreate = false) {
      const layoutMode = isMobileLayout() ? 'mobile' : 'desktop';
      const nextHost = getTerminalHost();
      if (!nextHost) {
        setNotice('终端容器不可用', 'error');
        return;
      }
      if (state.term && state.termLayoutMode === layoutMode && !forceRecreate) {
        return;
      }
      if (state.terminalMode === 'plain' && state.termLayoutMode === layoutMode && !forceRecreate) {
        return;
      }

      destroyTerminal();
      if (!window.Terminal || !window.FitAddon) {
        createPlainTerminal(nextHost, 'xterm 资源加载失败，已切换到纯文本兼容模式。');
        const activeSession = getActiveSession();
        if (activeSession) {
          setPlainTerminalContent(state.plainBufferBySession[activeSession.id] || '');
        }
        return;
      }

      state.term = new window.Terminal({
        cursorBlink: true,
        convertEol: true,
        scrollback: 4000,
        fontSize: 13,
        fontFamily: 'Consolas, "Cascadia Mono", "Courier New", monospace',
        theme: {
          background: '#040d1f',
          foreground: '#d8e4ff',
          cursor: '#8bb6ff',
          selectionBackground: 'rgba(139,182,255,0.25)'
        }
      });
      state.fitAddon = new window.FitAddon.FitAddon();
      state.term.loadAddon(state.fitAddon);
      state.termLayoutMode = layoutMode;
      state.terminalMode = 'xterm';
      state.term.open(nextHost);
      state.fitAddon.fit();
      const active = getActiveSession();
      if (active) {
        state.lastSeqBySession[active.id] = 0;
      } else {
        state.term.writeln('Remote terminal ready.');
      }
    }

    function ensureTerminal(forceRecreate = false) {
      const shouldMount = !isMobileLayout() || state.currentView === 'terminal';
      if (!shouldMount) {
        destroyTerminal();
        return;
      }

      initTerminal(forceRecreate);
      const active = getActiveSession();
      if (active && state.socket && state.connected) {
        resetTerminal(active.id);
        state.socket.emit('session:subscribe', { sessionId: active.id, historyLines: HISTORY_LINES });
      }
    }

    function fitTerminalAndResizeRemote() {
      if (state.terminalMode !== 'xterm' || !state.term || !state.fitAddon) return;
      state.fitAddon.fit();
      const active = getActiveSession();
      if (!active || !state.socket || !state.connected) return;
      state.socket.emit('session:resize', {
        sessionId: active.id,
        cols: state.term.cols,
        rows: state.term.rows
      });
    }

    function scheduleTerminalResize() {
      if (state.resizeTimer) clearTimeout(state.resizeTimer);
      state.resizeTimer = setTimeout(fitTerminalAndResizeRemote, RESIZE_DEBOUNCE_MS);
    }

    async function api(path, init) {
      const resp = await fetch(state.baseUrl + path, {
        ...init,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + token,
          ...(init && init.headers ? init.headers : {})
        }
      });
      const body = await resp.json().catch(() => ({}));
      if (!resp.ok) {
        const msg = body && body.message ? body.message : ('Request failed: ' + resp.status);
        throw new Error(msg);
      }
      return body.data;
    }

    async function probeBaseUrl(candidate) {
      const target = normalizeBaseUrl(candidate);
      if (!target) return { ok: false, baseUrl: target, reason: 'empty base url' };
      try {
        const resp = await fetch(target + '/api/health', {
          headers: { Authorization: 'Bearer ' + token }
        });
        const body = await resp.json().catch(() => ({}));
        if (!resp.ok) {
          return {
            ok: false,
            baseUrl: target,
            reason: body && body.message ? body.message : ('HTTP ' + resp.status)
          };
        }
        return { ok: true, baseUrl: target };
      } catch (err) {
        return {
          ok: false,
          baseUrl: target,
          reason: err && err.message ? err.message : String(err)
        };
      }
    }

    async function resolveWorkingBaseUrl(preferredBaseUrl) {
      const candidates = buildBaseUrlCandidates(preferredBaseUrl);
      let lastError = 'No candidate baseUrl';
      for (const candidate of candidates) {
        const result = await probeBaseUrl(candidate);
        if (result.ok) {
          applyBaseUrl(result.baseUrl);
          return;
        }
        lastError = result.baseUrl + ': ' + result.reason;
      }
      throw new Error('无法连接远程服务（请检查地址和 token）：' + lastError);
    }

    function getActiveSession() {
      return state.sessions.find((s) => s.id === state.activeSessionId) || null;
    }

    function updateActiveSessionView() {
      const session = getActiveSession();
      if (!session) {
        desktopActiveSessionTitle.textContent = '未选择会话';
        mobileActiveSessionTitle.textContent = '未选择会话';
        activeSessionMeta.textContent = '';
        updateInputAvailability();
        clearSessionActionButtons();
        return;
      }
      desktopActiveSessionTitle.textContent = session.name || session.id;
      mobileActiveSessionTitle.textContent = session.name || session.id;
      activeSessionMeta.textContent = [session.type, session.status, session.projectPath].join(' | ');
      updateInputAvailability();
      renderSessionActionButtons();
    }

    function resetTerminal(sessionId) {
      state.lastSeqBySession[sessionId] = 0;
      state.plainBufferBySession[sessionId] = '';
      if (state.terminalMode === 'xterm' && state.term) {
        state.term.clear();
        state.term.write('\x1b[2J\x1b[H');
        return;
      }
      if (state.terminalMode === 'plain') {
        setPlainTerminalContent('');
      }
    }

    function writeOutput(event) {
      if (!event || event.sessionId !== state.activeSessionId) return;
      if (typeof event.seq === 'number') {
        const prev = state.lastSeqBySession[event.sessionId] || 0;
        if (event.seq <= prev) return;
        state.lastSeqBySession[event.sessionId] = event.seq;
      }
      const raw = typeof event.data === 'string' ? event.data : String(event.data ?? '');
      if (!raw) return;
      if (state.terminalMode === 'xterm' && state.term) {
        state.term.write(raw);
        return;
      }
      if (state.terminalMode === 'plain') {
        appendPlainOutput(raw);
      }
    }

    function renderSessionList(target, list, mobile) {
      if (!target) return;
      target.textContent = '';

      if (list.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'muted';
        empty.textContent = '暂无匹配会话';
        target.appendChild(empty);
        return;
      }

      for (const s of list) {
        const el = document.createElement('div');
        if (mobile) {
          el.className = 'session-card';
          const nameEl = document.createElement('div');
          nameEl.className = 'session-card-name';
          nameEl.textContent = s.name || s.id;
          const metaEl = document.createElement('div');
          metaEl.className = 'session-card-meta';
          metaEl.textContent = [s.type, s.status].join(' | ');
          el.appendChild(nameEl);
          el.appendChild(metaEl);
        } else {
          el.className = 'session-item' + (s.id === state.activeSessionId ? ' active' : '');
          const nameEl = document.createElement('div');
          nameEl.className = 'session-item-name';
          nameEl.textContent = s.name || s.id;
          const metaEl = document.createElement('div');
          metaEl.className = 'session-item-meta';
          metaEl.textContent = [s.type, s.status].join(' | ');
          el.appendChild(nameEl);
          el.appendChild(metaEl);
        }
        el.addEventListener('click', () => selectSession(s.id));
        target.appendChild(el);
      }
    }

    function renderSessions() {
      const keyword = getSearchKeyword();
      const list = state.sessions.filter((s) => {
        if (!keyword) return true;
        return (
          (s.name || '').toLowerCase().includes(keyword) ||
          (s.id || '').toLowerCase().includes(keyword) ||
          (s.type || '').toLowerCase().includes(keyword)
        );
      });

      renderSessionList(desktopSessionListEl, list, false);
      renderSessionList(mobileSessionListEl, list, true);
      updateActiveSessionView();
    }

    function clearActiveTerminalOutput() {
      if (state.terminalMode === 'xterm' && state.term) {
        state.term.clear();
        state.term.write('\x1b[2J\x1b[H');
        return;
      }
      if (state.terminalMode === 'plain') {
        setPlainTerminalContent('');
      }
    }

    async function handleSessionControl(action) {
      const session = getActiveSession();
      if (!session) {
        setInlineNotice('请先选择会话', 'error');
        return;
      }
      if (state.controlBusyAction) return;
      if (action === 'destroy' && !window.confirm('确定要删除当前会话吗？')) {
        return;
      }

      state.controlBusyAction = action;
      renderSessionActionButtons();
      try {
        if (action === 'destroy' && state.socket) {
          state.socket.emit('session:unsubscribe', { sessionId: session.id });
        }

        if (action === 'start') {
          await api('/api/sessions/' + session.id + '/start', { method: 'POST' });
        } else if (action === 'pause') {
          await api('/api/sessions/' + session.id + '/pause', { method: 'POST' });
        } else if (action === 'restart') {
          await api('/api/sessions/' + session.id + '/restart', { method: 'POST' });
        } else if (action === 'destroy') {
          await api('/api/sessions/' + session.id, { method: 'DELETE' });
          clearActiveTerminalOutput();
        }

        await refreshData();
        if (action === 'destroy') {
          setInlineNotice('会话已删除', 'ok');
        } else {
          setInlineNotice('会话已' + (action === 'start' ? '启动' : action === 'pause' ? '暂停' : '重启'), 'ok');
        }
      } catch (error) {
        setInlineNotice(
          (action === 'start' ? '启动' : action === 'pause' ? '暂停' : action === 'restart' ? '重启' : '删除') +
            '失败: ' +
            (error && error.message ? error.message : String(error)),
          'error'
        );
      } finally {
        state.controlBusyAction = '';
        renderSessionActionButtons();
      }
    }

    function selectSession(sessionId) {
      const isSameSession = state.activeSessionId === sessionId;

      if (isSameSession && !isMobileLayout()) return;

      if (!isSameSession && state.activeSessionId && state.socket) {
        state.socket.emit('session:unsubscribe', { sessionId: state.activeSessionId });
      }

      if (!isSameSession) {
        state.activeSessionId = sessionId;
        resetTerminal(sessionId);
        renderSessions();
        setInlineNotice('');
      }

      if (isMobileLayout()) {
        switchToView('terminal');
      } else {
        ensureTerminal();
      }

      if (!isSameSession && state.socket) {
        state.socket.emit('session:subscribe', { sessionId, historyLines: HISTORY_LINES }, (ack) => {
          if (ack && ack.ok === false) {
            setInlineNotice('订阅失败: ' + (ack.message || 'unknown'), 'error');
          }
        });
      }
      scheduleTerminalResize();
    }

    async function refreshData() {
      const sessions = await api('/api/sessions');
      let normalized = Array.isArray(sessions) ? sessions.slice() : [];
      if (PASSTHROUGH_ONLY) {
        normalized = normalized.filter((s) => s && s.status === 'running' && !!s.processId);
      }
      normalized.sort((a, b) => (b.lastActiveAt || 0) - (a.lastActiveAt || 0));
      state.sessions = normalized;

      if (state.activeSessionId && !state.sessions.some((s) => s.id === state.activeSessionId)) {
        state.activeSessionId = null;
      }

      renderSessions();
      if (!state.activeSessionId && state.sessions.length > 0) {
        selectSession(state.sessions[0].id);
      }
    }

    function connectSocket() {
      if (state.socket) {
        state.socket.removeAllListeners();
        state.socket.disconnect();
      }
      const socket = io(state.baseUrl, {
        transports: ['polling', 'websocket'],
        tryAllTransports: true,
        auth: { token },
        reconnection: true,
        reconnectionDelay: 500,
        reconnectionDelayMax: 6000
      });
      state.socket = socket;

      socket.on('connect', () => {
        state.idleTimeoutPending = false;
        state.lastSocketError = '';
        state.socketReconnectInFlight = false;
        setSocketUi(true, 'connected');
        clearGlobalNotice();
        setInlineNotice('实时通道已连接', 'ok');
        const active = getActiveSession();
        if (active) {
          ensureTerminal(true);
          resetTerminal(active.id);
          socket.emit('session:subscribe', { sessionId: active.id, historyLines: HISTORY_LINES });
          scheduleTerminalResize();
        }
      });

      socket.on('system:idle-timeout', (event) => {
        state.idleTimeoutPending = true;
        const message = event && event.message ? event.message : '连接因空闲被服务端断开';
        setSocketUi(false, 'idle-timeout');
        setGlobalNotice(message + '，正在尝试重连...', 'error');
      });

      socket.on('disconnect', (reason) => {
        const isServerDisconnect = reason === 'io server disconnect';
        if (state.idleTimeoutPending) {
          setSocketUi(false, 'idle-timeout');
          setGlobalNotice('连接因空闲被断开，正在重新连接...', 'error');
        } else {
          const detail = state.lastSocketError ? 'disconnected (' + state.lastSocketError + ')' : 'disconnected';
          setSocketUi(false, detail);
          setGlobalNotice('实时通道已断开，正在重连...', 'error');
        }
        if (isServerDisconnect) {
          setTimeout(() => {
            state.idleTimeoutPending = false;
            socket.connect();
          }, 600);
          return;
        }
        state.idleTimeoutPending = false;
      });

      socket.on('connect_error', (err) => {
        const message = err && err.message ? err.message : 'unknown';
        state.lastSocketError = message;
        setSocketUi(false, 'error: ' + message);
        setGlobalNotice('连接失败: ' + message, 'error');
        const shouldRetryAlternateBase =
          !state.socketReconnectInFlight &&
          !/unauthorized|invalid|token|forbidden/i.test(String(message));

        if (shouldRetryAlternateBase) {
          state.socketReconnectInFlight = true;
          const currentAttemptBaseUrl = state.baseUrl;
          void resolveWorkingBaseUrl(fallbackOrigin || defaultBaseUrl)
            .then(() => {
              if (state.baseUrl === currentAttemptBaseUrl) return;
              setGlobalNotice('正在切换到可用的远程地址并重连...', 'error');
              connectSocket();
            })
            .catch(() => {
              // 保留当前错误展示，等待 socket.io 自己重试
            })
            .finally(() => {
              state.socketReconnectInFlight = false;
            });
        }
      });

      socket.on('session:output', writeOutput);

      socket.on('session:status', (event) => {
        const target = state.sessions.find((s) => s.id === event.sessionId);
        if (target) target.status = event.status;
        renderSessions();
      });
    }

    async function safeAction(label, fn) {
      try {
        await fn();
      } catch (err) {
        setInlineNotice(label + '失败: ' + (err && err.message ? err.message : String(err)), 'error');
      }
    }

    refreshBtn.addEventListener('click', () => safeAction('刷新', async () => {
      await refreshData();
      setInlineNotice('已刷新', 'ok');
    }));

    function handleSearchInput(event) {
      const value = event && event.target ? event.target.value : '';
      syncSearchInputs(value);
      renderSessions();
    }

    desktopSearchInput.addEventListener('input', handleSearchInput);
    mobileSearchInput.addEventListener('input', handleSearchInput);

    function sendCurrentInput(sourceInput) {
      const session = getActiveSession();
      if (!session) {
        setInlineNotice('请先选择会话', 'error');
        updateInputAvailability();
        return;
      }
      if (!state.socket || !state.connected) {
        setGlobalNotice('实时通道未连接，暂时无法发送输入。', 'error');
        updateInputAvailability();
        return;
      }
      const raw = sourceInput ? sourceInput.value : '';
      if (!raw || !raw.trim()) return;

      const payload = { sessionId: session.id, input: raw };
      const onAck = (ack) => {
        if (ack && ack.ok === false) {
          setInlineNotice('发送失败: ' + (ack.message || 'unknown'), 'error');
          return;
        }
        clearGlobalNotice();
        clearInputBoxes();
        setInlineNotice('已发送到会话', 'ok');
        sourceInput.focus();
      };

      if (typeof state.socket.timeout === 'function') {
        state.socket.timeout(4000).emit('session:input', payload, (err, ack) => {
          if (err) {
            setInlineNotice('发送超时，请检查连接状态后重试。', 'error');
            return;
          }
          onAck(ack);
        });
        return;
      }

      state.socket.emit('session:input', payload, onAck);
    }

    function bindInputEvents(inputEl, buttonEl) {
      buttonEl.addEventListener('click', () => sendCurrentInput(inputEl));
      inputEl.addEventListener('keydown', (e) => {
        if (e.isComposing) return;
        if (e.key === 'Enter') {
          e.preventDefault();
          sendCurrentInput(inputEl);
        }
      });
    }

    bindInputEvents(desktopInputBox, desktopSendBtn);
    bindInputEvents(mobileInputBox, mobileSendBtn);
    updateInputAvailability();

    logoutBtn.addEventListener('click', () => {
      sessionStorage.removeItem(keyToken);
      sessionStorage.removeItem(keyBase);
      localStorage.removeItem(keyToken);
      localStorage.removeItem(keyBase);
      localStorage.removeItem(keyRemember);
      location.href = '/login';
    });

    // 虚拟键盘适配
    function bindKeyboardAwareInput(inputEl) {
      if (!inputEl) return;
      inputEl.addEventListener('focus', () => {
        document.body.classList.add('keyboard-open');
        setTimeout(scheduleTerminalResize, 300);
      });
      inputEl.addEventListener('blur', () => {
        document.body.classList.remove('keyboard-open');
        setTimeout(scheduleTerminalResize, 300);
      });
    }

    bindKeyboardAwareInput(desktopInputBox);
    bindKeyboardAwareInput(mobileInputBox);

    // visualViewport API 精确检测
    if (window.visualViewport) {
      window.visualViewport.addEventListener('resize', () => {
        const viewportHeight = window.visualViewport.height;
        const windowHeight = window.innerHeight;
        if (viewportHeight < windowHeight * 0.75) {
          document.body.classList.add('keyboard-open');
        } else {
          document.body.classList.remove('keyboard-open');
        }
        scheduleTerminalResize();
      });
    }

    function bindTerminalTouchInteractions(targetHost) {
      if (!targetHost) return;

      let longPressTimer = null;
      let touchStartX = 0;
      let touchStartY = 0;

      targetHost.addEventListener('touchstart', (e) => {
        if (!isMobileLayout()) return;
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        longPressTimer = setTimeout(() => {
          if (state.term) {
            const selection = state.term.getSelection();
            if (selection) {
              navigator.clipboard.writeText(selection).then(() => {
                setInlineNotice('已复制到剪贴板', 'ok');
              }).catch(() => {
                setInlineNotice('复制失败', 'error');
              });
            }
          }
        }, 600);
      });

      targetHost.addEventListener('touchmove', (e) => {
        const moveX = Math.abs(e.touches[0].clientX - touchStartX);
        const moveY = Math.abs(e.touches[0].clientY - touchStartY);
        if (moveX > 10 || moveY > 10) {
          clearTimeout(longPressTimer);
        }
      });

      targetHost.addEventListener('touchend', () => {
        clearTimeout(longPressTimer);
      });
    }

    bindTerminalTouchInteractions(desktopTerminalHost);
    bindTerminalTouchInteractions(mobileTerminalHost);

    function syncResponsiveLayout(forceRecreate = false) {
      if (isMobileLayout()) {
        switchToView(state.currentView === 'terminal' && state.activeSessionId ? 'terminal' : 'sessions');
        return;
      }
      document.body.className = '';
      ensureTerminal(forceRecreate);
      scheduleTerminalResize();
    }

    window.addEventListener('resize', scheduleTerminalResize);
    window.addEventListener('resize', () => syncResponsiveLayout(true));
    if (mobileMedia && typeof mobileMedia.addEventListener === 'function') {
      mobileMedia.addEventListener('change', () => syncResponsiveLayout(true));
    }
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) return;
      void safeAction('刷新', refreshData);
    });

    setInterval(() => {
      if (document.hidden) return;
      void safeAction('刷新', refreshData);
    }, LIST_AUTO_REFRESH_INTERVAL_MS);

    (async () => {
      syncResponsiveLayout(true);
      try {
        await resolveWorkingBaseUrl();
        await loadRemoteCapabilities();
        connectSocket();
        await refreshData();
        scheduleTerminalResize();
      } catch (err) {
        const message = err && err.message ? err.message : String(err);
        state.lastSocketError = message;
        setSocketUi(false, 'init-failed');
        setGlobalNotice('初始化失败: ' + message, 'error');
        setInlineNotice('页面初始化未完成，请先排查顶部错误提示。', 'error');
      }
    })();
  </script>
</body>
</html>`;
}
