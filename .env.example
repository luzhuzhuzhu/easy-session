# EasySession Remote MVP
# Copy this file to ".env" in project root and modify values.

EASYSESSION_REMOTE_ENABLED=true
# Full passthrough (recommended): remote side only subscribes existing sessions and sends input.
# Set false only if you explicitly need remote lifecycle control (create/start/restart/delete).
EASYSESSION_REMOTE_PASSTHROUGH_ONLY=true
EASYSESSION_REMOTE_HOST=127.0.0.1
EASYSESSION_REMOTE_PORT=18765

# Use a random token with at least 64 chars.
EASYSESSION_REMOTE_TOKEN=replace_with_your_64_plus_char_random_token

# 30 minutes
EASYSESSION_REMOTE_IDLE_TIMEOUT_MS=1800000

# Basic rate limit (per IP + method + path)
EASYSESSION_REMOTE_RATE_LIMIT_WINDOW_MS=60000
EASYSESSION_REMOTE_RATE_LIMIT_MAX=240

# Optional CLI auth/env (forwarded to spawned CLI processes)
# Use this if Codex CLI shows: "Not logged in  Run /login"
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
